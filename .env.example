# ─────────────────────────────────────────────────────────────────────────────
# EcoTrack AI — Environment Configuration
# Copy this file to .env and fill in the values for your environment.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────────────────

# Application server port
PORT=5000

# Node environment: development | production
NODE_ENV=development

# ── Database ─────────────────────────────────────────────────────────────────

# Local development (SQLite — zero config, auto-created)
DATABASE_URL="file:./prisma/dev.db"

# Production (PostgreSQL on Cloud SQL or AlloyDB)
# DATABASE_URL="postgresql://user:password@host:5432/ecotrack?schema=public"

# ── Google Gemini AI ─────────────────────────────────────────────────────────
# Enables AI-powered explainable coaching and carbon forecasting.
# Without this key, the app uses the built-in rule-based fallback engine.
#
# Get your key at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=

# ── Firebase Authentication ───────────────────────────────────────────────────
# Enables Firebase JWT token verification on all API routes.
# Without these, the app uses a developer mock user (dev-user-001).
#
# Option A: Individual credential variables
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Option B: Full service account JSON (alternative to Option A)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# ── Google Cloud ─────────────────────────────────────────────────────────────
# Used for Cloud Run deployment and Artifact Registry
GOOGLE_CLOUD_PROJECT=
GCP_REGION=us-central1

# ── Security ─────────────────────────────────────────────────────────────────
# CORS allowed origins (comma-separated, production only)
# ALLOWED_ORIGINS=https://ecotrack-ai-xxxx-uc.a.run.app
